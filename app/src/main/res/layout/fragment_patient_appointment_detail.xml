<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- ========================================== -->
        <!-- SECTION 1: HEADER (Always Visible)         -->
        <!-- ========================================== -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Navigate back"
            android:src="@drawable/arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_black" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:text="Appointment Details"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btnBack" />

        <!-- ========================================== -->
        <!-- SECTION 2a: DOCTOR INFO CARD               -->
        <!-- ========================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDoctorInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/colorBackground"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnBack"
            app:strokeColor="#F5F5F5"
            app:strokeWidth="1dp"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgDoctor"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/doctor"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvDoctorName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/imgDoctor"
                    app:layout_constraintTop_toTopOf="@+id/imgDoctor"
                    tools:text="Dr. Ahmad Hassan" />

                <TextView
                    android:id="@+id/tvDoctorSpecialization"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/tvDoctorName"
                    app:layout_constraintTop_toBottomOf="@+id/tvDoctorName"
                    tools:text="Cardiologist" />

                <TextView
                    android:id="@+id/tvDoctorAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:contentDescription="Doctor clinic address"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/tvDoctorName"
                    app:layout_constraintTop_toBottomOf="@+id/tvDoctorSpecialization"
                    tools:text="Johar Town, Lahore"
                    tools:visibility="visible" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================================== -->
        <!-- SECTION 2b: LAB INFO CARD                  -->
        <!-- ========================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLabInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/colorBackground"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnBack"
            app:strokeColor="#F5F5F5"
            app:strokeWidth="1dp"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgLabIcon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_white_rounded"
                    android:backgroundTint="#F0F8FF"
                    android:padding="14dp"
                    android:src="@drawable/research"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/primary_blue" />

                <TextView
                    android:id="@+id/tvTestName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/imgLabIcon"
                    app:layout_constraintTop_toTopOf="@+id/imgLabIcon"
                    tools:text="Complete Blood Count" />

                <TextView
                    android:id="@+id/tvLabName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/tvTestName"
                    app:layout_constraintTop_toBottomOf="@+id/tvTestName"
                    tools:text="Chughtai Lab" />

                <TextView
                    android:id="@+id/tvTestType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/tvTestName"
                    app:layout_constraintTop_toBottomOf="@+id/tvLabName"
                    tools:text="Blood Test" />

                <TextView
                    android:id="@+id/tvLabAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:contentDescription="Lab address"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/tvTestName"
                    app:layout_constraintTop_toBottomOf="@+id/tvTestType"
                    tools:text="DHA Phase 5, Lahore"
                    tools:visibility="visible" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Barrier 1: Safe anchoring below Info Cards (includes btnBack to prevent layout collapse) -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrierBelowInfoCards"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="cardDoctorInfo,cardLabInfo,btnBack" />

        <!-- ========================================== -->
        <!-- APPOINTMENT INFO + CANCEL   -->
        <!-- ========================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAppointmentInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/colorBackground"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/barrierBelowInfoCards"
            app:strokeColor="#F5F5F5"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header Row: Title + Status Chip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:text="Appointment Details"
                        android:textColor="@color/text_black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chipStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_white_rounded"
                        android:fontFamily="@font/poppins"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/warning"
                        tools:text="Pending" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:contentDescription="Appointment date"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_black"
                    android:textSize="14sp"
                    app:drawableStartCompat="@android:drawable/ic_menu_my_calendar"
                    app:drawableTint="@color/gray_1"
                    tools:text="24 Jan 2026" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:contentDescription="Appointment time"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_black"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
                    app:drawableTint="@color/gray_1"
                    tools:text="10:00 AM" />

                <TextView
                    android:id="@+id/tvReasonOrType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:contentDescription="Reason or test type"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_black"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    app:drawableStartCompat="@android:drawable/ic_menu_info_details"
                    app:drawableTint="@color/gray_1"
                    tools:text="General Consultation" />

                <!-- Divider — shown for both cancel and review actions -->
                <View
                    android:id="@+id/dividerAction"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="#E0E0E0"
                    android:importantForAccessibility="no"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Cancel button — pending/confirmed only -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/poppins"
                    android:padding="12dp"
                    android:text="Cancel Appointment"
                    android:textAllCaps="false"
                    android:textColor="@color/error"
                    android:textSize="15sp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/error"
                    app:strokeWidth="1.5dp"
                    tools:visibility="visible" />

                <!-- Review section — completed appointments only -->
                <LinearLayout
                    android:id="@+id/layoutReviewAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <!-- Stars display — shown when review already submitted -->
                    <LinearLayout
                        android:id="@+id/layoutExistingReview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tvYourReview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="@font/poppins"
                            android:text="Your Review"
                            android:textColor="@color/text_hint"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <RatingBar
                            android:id="@+id/ratingBarDisplay"
                            style="@style/Widget.AppCompat.RatingBar.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:rating="0"
                            android:stepSize="1"
                            android:progressTint="#FFB300"
                            android:secondaryProgressTint="#FFB300" />

                        <TextView
                            android:id="@+id/tvExistingComment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/text_black"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="Great experience, very professional" />
                    </LinearLayout>

                    <!-- Write review button — shown when no review yet -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWriteReview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/poppins"
                        android:padding="12dp"
                        app:backgroundTint="@color/blue_button"
                        android:text="Write a Review"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:visibility="gone"
                        app:cornerRadius="16dp"
                        app:icon="@android:drawable/btn_star_big_off"
                        app:iconGravity="textStart"
                        tools:visibility="visible" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================================== -->
        <!-- SECTION 5: PRESCRIPTION SECTION            -->
        <!-- ========================================== -->
        <LinearLayout
            android:id="@+id/layoutPrescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardAppointmentInfo"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins"
                android:text="Prescription"
                android:textColor="@color/text_black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPrescriptionContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorBackground"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Empty State -->
                    <TextView
                        android:id="@+id/tvNoPrescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Doctor has not added a prescription yet"
                        android:textColor="@color/text_hint"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Populated State -->
                    <LinearLayout
                        android:id="@+id/layoutPrescriptionDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tvPrescriptionIssuedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"
                            tools:text="Issued: 24 Jan 2026" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="12dp"
                            android:background="#E0E0E0"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:text="Diagnosis"
                            android:textColor="@color/primary_blue"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPrescriptionDiagnosis"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/text_black"
                            android:textSize="14sp"
                            tools:text="Viral Infection" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="12dp"
                            android:background="#E0E0E0"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:text="Medications"
                            android:textColor="@color/primary_blue"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPrescriptionMedications"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/poppins"
                            android:lineSpacingExtra="4dp"
                            android:textColor="@color/text_black"
                            android:textSize="14sp"
                            tools:text="• Paracetamol 500mg\n• Vitamin C" />

                        <TextView
                            android:id="@+id/tvPrescriptionInstructions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/text_black"
                            android:textSize="14sp"
                            android:visibility="gone"
                            tools:text="Instructions: Take after meals"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/tvFollowUpDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/primary_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:text="Follow-up: 30 Jan 2026"
                            tools:visibility="visible" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ========================================== -->
        <!-- SECTION 6: LAB REPORT SECTION              -->
        <!-- ========================================== -->
        <LinearLayout
            android:id="@+id/layoutLabReport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardAppointmentInfo"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins"
                android:text="Lab Report"
                android:textColor="@color/text_black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLabReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorBackground"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Empty State -->
                    <TextView
                        android:id="@+id/tvNoLabReport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Lab report has not been uploaded yet"
                        android:textColor="@color/text_hint"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Populated State -->
                    <LinearLayout
                        android:id="@+id/layoutLabReportDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tvResultSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/text_black"
                            android:textSize="14sp"
                            android:visibility="gone"
                            tools:text="Result: Normal limits observed."
                            tools:visibility="visible" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewReport"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/poppins"
                            app:backgroundTint="@color/primary_blue"
                            android:padding="12dp"
                            android:text="View Full Report"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Barrier 2: Safe anchoring at the bottom -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrierBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="cardAppointmentInfo,layoutPrescription,layoutLabReport" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReportIssue"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/poppins"
            android:padding="10dp"
            android:text="Report an Issue"
            android:textAllCaps="false"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/ic_dialog_alert"
            app:iconGravity="textStart"
            app:iconTint="@color/text_hint"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/barrierBottom"
            app:strokeColor="@color/text_hint"
            app:strokeWidth="1dp" />


        <!-- Spacer pushes scroll view to accommodate padding visually against bottom barrier -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/barrierBottom" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>