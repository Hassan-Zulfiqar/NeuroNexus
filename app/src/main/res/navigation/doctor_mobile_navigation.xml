<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/doctor_mobile_navigation"
    app:startDestination="@+id/navigation_doctor_home">

    <fragment
        android:id="@+id/navigation_doctor_home"
        android:name="com.example.neuronexus.doctor.ui.home.DoctorHomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_doctor_home" >

    <action
        android:id="@+id/action_home_to_detail"
        app:destination="@id/navigation_doctor_appointment_detail" />

    </fragment>


    <fragment
        android:id="@+id/navigation_doctor_search"
        android:name="com.example.neuronexus.doctor.ui.search.DoctorSearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_doctor_search" />

    <fragment
        android:id="@+id/navigation_doctor_schedule"
        android:name="com.example.neuronexus.doctor.ui.schedule.DoctorScheduleFragment"
        android:label="Schedule"
        tools:layout="@layout/fragment_doctor_schedule">
        <!-- NEW ACTION -->
        <action
            android:id="@+id/action_schedule_to_detail"
            app:destination="@id/navigation_doctor_appointment_detail" />

        <!-- from Schedule to Add Prescription -->
        <action
            android:id="@+id/action_schedule_to_add_prescription"
            app:destination="@id/navigation_add_prescription" />
    </fragment>

    <fragment
        android:id="@+id/navigation_doctor_profile"
        android:name="com.example.neuronexus.doctor.ui.profile.DoctorProfileFragment"
        android:label="My Profile"
        tools:layout="@layout/fragment_doctor_profile" />

    <fragment
        android:id="@+id/navigation_doctor_edit_profile"
        android:name="com.example.neuronexus.doctor.ui.profile.DoctorEditProfileFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_doctor_edit_profile" />

    <fragment
        android:id="@+id/navigation_doctor_history"
        android:name="com.example.neuronexus.doctor.ui.history.DoctorHistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_doctor_history">
        <!-- NEW ACTION -->
        <action
            android:id="@+id/action_history_to_detail"
            app:destination="@id/navigation_doctor_appointment_detail" />
    </fragment>

    <!-- NEW DETAIL DESTINATION -->
    <fragment
        android:id="@+id/navigation_doctor_appointment_detail"
        android:name="com.example.neuronexus.doctor.ui.detail.DoctorAppointmentDetailFragment"
        android:label="Appointment Details"
        tools:layout="@layout/fragment_doctor_appointment_detail" >

        <!--  Action from Detail to Patient History -->
        <action
            android:id="@+id/action_detail_to_doctor_patient_timeline"
            app:destination="@id/navigation_doctor_patient_timeline" />

        <!-- Action from Detail to Prescription -->
        <action
            android:id="@+id/action_detail_to_add_prescription"
            app:destination="@id/navigation_add_prescription" />
    </fragment>


    <!-- Patient Timeline Destination -->
    <fragment
        android:id="@+id/navigation_doctor_patient_timeline"
        android:name="com.example.neuronexus.doctor.ui.patienttimeline.DoctorPatientTimelineFragment"
        android:label="DoctorPatientTimelineFragment">

        <action
            android:id="@+id/action_doctor_patient_timeline_to_detail"
            app:destination="@id/navigation_doctor_appointment_detail" />

    </fragment>

    <fragment
        android:id="@+id/navigation_add_prescription"
        android:name="com.example.neuronexus.doctor.ui.prescription.AddPrescriptionFragment"
        android:label="AddPrescriptionFragment">

        <action
            android:id="@+id/action_add_prescription_to_detail"
            app:destination="@id/navigation_doctor_appointment_detail"
            app:popUpTo="@id/navigation_add_prescription"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/navigation_submit_complaint"
        android:name="com.example.neuronexus.common.ui.SubmitComplaintFragment"
        android:label="SubmitComplaintFragment" />

    <action
        android:id="@+id/action_global_to_submit_complaint"
        app:destination="@id/navigation_submit_complaint" />

</navigation>